<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set the base directory (adjust if your app is in a subdirectory)
    RewriteBase /
    
    # Allow direct access to actual files and directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Route everything else through index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
    
    # Block direct access to PHP files via URL
    # (This won't affect server-side includes/requires)
    RewriteCond %{THE_REQUEST} \s/+[^?]*\.php[\s?] [NC]
    RewriteCond %{REQUEST_URI} !^/index\.php$ [NC]
    RewriteRule ^ - [F,L]
</IfModule>